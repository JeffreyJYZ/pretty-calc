{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pretty Calc",
	"version": "0.1.0",
	"identifier": "com.jyz.pretty-calc",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Pretty Calc",
				"width": 940,
				"height": 880,
				"minWidth": 340,
				"minHeight": 560,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"iOS": {
			"infoPlist": "Info.ios.plist"
		},
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
